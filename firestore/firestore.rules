rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── HELPERS ────────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    // ─── USERS ───────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuth() && request.auth.uid == userId;
      allow update: if isOwner(userId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'uid', 'createdAt']);
      allow delete: if isAdmin();
    }

    // ─── TOOLS ───────────────────────────────────────────────
    match /tools/{toolId} {
      allow read: if true; // public
      allow write: if isAdmin();
    }

    // ─── SLOTS ───────────────────────────────────────────────
    match /slots/{slotId} {
      allow read: if true; // public (availability shown to all)
      allow write: if isAdmin();
    }

    // ─── BOOKINGS ────────────────────────────────────────────
    match /bookings/{bookingId} {
      allow read: if isAdmin() || (isAuth() && resource.data.userId == request.auth.uid);
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      // Client can only update payment proof fields
      allow update: if isAdmin() ||
        (isAuth() &&
          resource.data.userId == request.auth.uid &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['paymentReference', 'paymentProofUrl', 'updatedAt']));
      allow delete: if isAdmin();
    }

    // ─── REVIEWS ─────────────────────────────────────────────
    match /reviews/{reviewId} {
      allow read: if resource.data.approved == true || isAdmin();
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ─── NOTIFICATIONS ───────────────────────────────────────
    match /notifications/{notifId} {
      allow read: if isAdmin() || (isAuth() && resource.data.userId == request.auth.uid);
      allow create: if isAdmin();
      allow update: if isAuth() && resource.data.userId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow delete: if isAdmin();
    }

    // ─── MESSAGES ────────────────────────────────────────────
    match /messages/{messageId} {
      allow read: if isAdmin() || (isAuth() && resource.data.userId == request.auth.uid);
      allow create: if isAdmin();
      allow delete: if isAdmin();
    }

    // ─── ACTIVITY LOG ────────────────────────────────────────
    match /activityLog/{logId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // ─── SETTINGS ────────────────────────────────────────────
    match /settings/{settingId} {
      allow read: if true; // public (site content, payment info)
      allow write: if isAdmin();
    }
  }
}
